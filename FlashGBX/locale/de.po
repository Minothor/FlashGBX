msgstr "stellt die Sprache des Programms ein (z. B. „auto“, „en“, „de”, ...)"

#: ../package/FlashGBX/FlashGBX.py:179
msgctxt "Command Line Arguments Category"
msgid "Configuration arguments"
msgstr "Konfigurations-Parameter"

#: ../package/FlashGBX/FlashGBX.py:180
#, python-brace-format
msgctxt "Configuration Help"
msgid ""
"sets the config directory to either the OS-provided local app config "
"directory ({appdata}), or a subdirectory of this application ({subdir})"
msgstr ""
"setzt das Konfigurationsverzeichnis auf den vom Betriebssystem "
"vorgeschlagenen Ordner ({appdata}) oder auf einen Unterordner dieser "
"Anwendung ({subdir})"

#: ../package/FlashGBX/FlashGBX.py:182
msgctxt "Command Line Arguments Category"
msgid "Main command line interface arguments"
msgstr "Hauptsächliche Kommandozeilen-Parameter"

#: ../package/FlashGBX/FlashGBX.py:183
msgctxt "Command Line Help"
msgid "set platform to “dmg” (Game Boy) or “agb” (Game Boy Advance)"
msgstr "setzt die Plattform auf „dmg” (Game Boy) oder „agb” (Game Boy Advance)"

#: ../package/FlashGBX/FlashGBX.py:184
msgctxt "Command Line Help"
msgid "select program action"
msgstr "Programmfunktion wählen"

#: ../package/FlashGBX/FlashGBX.py:185
msgctxt "Command Line Help"
msgid "overwrite without asking if target file already exists"
msgstr "vorhandene Dateien ohne Nachfrage überschreiben"

#: ../package/FlashGBX/FlashGBX.py:186
msgctxt "Command Line Help"
msgid ""
"target or source file path (optional when reading, required when writing)"
msgstr ""
"Ziel- oder Quell-Dateipfad (beim Lesen optional, beim Schreiben erforderlich)"

#: ../package/FlashGBX/FlashGBX.py:188
msgctxt "Command Line Arguments Category"
msgid "Optional command line interface arguments"
msgstr "Optionale Kommandozeilen-Parameter"

#: ../package/FlashGBX/FlashGBX.py:189
msgctxt "Command Line Help"
msgid "set size of Game Boy cartridge ROM data"
msgstr "setzt die ROM-Daten-Größe für Game-Boy-Spielmodule"

#: ../package/FlashGBX/FlashGBX.py:190
msgctxt "Command Line Help"
msgid "set mapper type of Game Boy cartridge"
msgstr "setzt den Mapper-Typ für Game-Boy-Spielmodule"

#: ../package/FlashGBX/FlashGBX.py:191
msgctxt "Command Line Help"
msgid "set type of Game Boy cartridge save data"
msgstr "setzt die Spielstand-Daten-Größe für Game-Boy-Spielmodule"

#: ../package/FlashGBX/FlashGBX.py:192
msgctxt "Command Line Help"
msgid "set size of Game Boy Advance cartridge ROM data"
msgstr "setzt die ROM-Daten-Größe für Game-Boy-Advance-Spielmodule"

#: ../package/FlashGBX/FlashGBX.py:193
msgctxt "Command Line Help"
msgid "set type of Game Boy Advance cartridge save data"
msgstr "setzt die Spielstand-Daten-Größe für Game-Boy-Advance-Spielmodule"

#: ../package/FlashGBX/FlashGBX.py:194
#, python-brace-format
msgctxt "Command Line Help"
msgid ""
"Location of Batteryless SRAM data in ROM (e.g. 0xFC0000); only with "
"“{dmg_savetype_batteryless}” or “{agb_savetype_batteryless}”)"
msgstr ""
"Speicherort der Batteryless-SRAM-Daten im ROM (z. B. 0xFC0000); nur mit "
"„{dmg_savetype_batteryless}“ oder „{agb_savetype_batteryless}“"

#: ../package/FlashGBX/FlashGBX.py:195
msgctxt "Command Line Help"
msgid "Size of Batteryless SRAM data in ROM (e.g. 0x10000)"
msgstr "Größe der Batteryless-SRAM-Daten im ROM (z. B. 0x10000)"

#: ../package/FlashGBX/FlashGBX.py:196
msgctxt "Command Line Help"
msgid ""
"Bank layout of Batteryless SRAM data for DMG mode: 0=continuous, 1=first "
"half of ROM bank, 2=second half"
msgstr ""
"Bank-Layout der Batteryless-SRAM-Daten beim DMG-Modus: 0=fortlaufend, "
"1=erste Hälfte einer ROM-Bank, 2=zweite Hälfte einer ROM-Bank"

#: ../package/FlashGBX/FlashGBX.py:197
msgctxt "Command Line Help"
msgid "store RTC register values if supported"
msgstr "speichert die Echzeituhr-Registerwerte, falls unterstützt"

#: ../package/FlashGBX/FlashGBX.py:198
msgctxt "Command Line Help"
msgid "keep existing calibration data of the e-Reader when writing save data"
msgstr ""
"vorhandene e-Reader-Kalibrierungsdaten beim Schreiben von Spielstand-Daten "
"erhalten"

#: ../package/FlashGBX/FlashGBX.py:199
msgctxt "Command Line Help"
msgid "don’t stop if invalid data found in cartridge header data"
msgstr "bei ungültigen Spielmodul-Header-Daten nicht anhalten"

#: ../package/FlashGBX/FlashGBX.py:200
msgctxt "Command Line Help"
msgid "name of flash cart profile; see .txt files in config directory"
msgstr ""
"Name des Flashkarten-Profils; siehe .txt-Dateien im Konfigurationsverzeichnis"

#: ../package/FlashGBX/FlashGBX.py:201
msgctxt "Command Line Help"
msgid "prefer full chip erase over sector erase when both available"
msgstr ""
"vollständige Chip-Löschung der Sektoren-Löschung vorziehen, wenn beides "
"verfügbar ist"

#: ../package/FlashGBX/FlashGBX.py:202
msgctxt "Command Line Help"
msgid "force 5V when writing Game Boy flash cartridges"
msgstr "beim Schreiben von Game-Boy-Flashkarten 5 Volt erzwingen"

#: ../package/FlashGBX/FlashGBX.py:203
msgctxt "Command Line Help"
msgid "do not verify written data"
msgstr "geschriebene Daten nicht gegenprüfen"

#: ../package/FlashGBX/FlashGBX.py:204
msgctxt "Command Line Help"
msgid "generate a dump report for a ROM backup"
msgstr "für ein ROM-Backup einen Dump-Report schreiben"

#: ../package/FlashGBX/FlashGBX.py:205
msgctxt "Command Line Help"
msgid "adds a timestamp to the file name of save data backups"
msgstr "Datum && Uhrzeit den Spielstand-Dateinamen anhängen"

#: ../package/FlashGBX/FlashGBX.py:206
msgctxt "Command Line Help"
msgid "sets the color palette of pictures extracted from Game Boy Camera saves"
msgstr ""
"setzt die Farbpalette der aus einem Spielstand extrahierten Game-Boy-Camera-"
"Fotos"

#: ../package/FlashGBX/FlashGBX.py:207
msgctxt "Command Line Help"
msgid ""
"sets the file format of saved pictures extracted from Game Boy Camera saves"
msgstr ""
"setzt das Dateiformat der aus einem Spielstand extrahierten Game-Boy-Camera-"
"Fotos"

#: ../package/FlashGBX/FlashGBX.py:208
msgctxt "Command Line Help"
msgid ""
"automatically extract Game Boy Camera pictures after backing up save data"
msgstr ""
