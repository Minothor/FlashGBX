#: ../package/FlashGBX/FlashGBX.py:209
msgctxt "Command Line Help"
msgid "override device port"
msgstr "Geräte-Port überschreiben"

#: ../package/FlashGBX/FlashGBX.py:210
msgctxt "Command Line Help"
msgid "limit connection to a slower baud rate"
msgstr "begrenzt die Verbindung auf eine langsamere Baudrate"

#: ../package/FlashGBX/FlashGBX.py:211
msgctxt "Command Line Help"
msgid ""
"compare sectors and only write those that differ when writing a ROM (only "
"for flash carts that support this feature)"
msgstr ""
"Beim ROM-Schreiben Sektoren vergleichen und nur solche schreiben, die sich "
"unterscheiden (nur für Flashkarten, die es unterstützen)"

#: ../package/FlashGBX/FlashGBX.py:212
